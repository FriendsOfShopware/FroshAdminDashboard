{% block frosh_widget_recent_customers %}
<div class="frosh-widget-recent-customers">

    {% block frosh_widget_recent_customers_no_acl %}
    <div v-if="!acl.can('customer.viewer')" class="frosh-widget-recent-customers__empty">
        {{ $tc('frosh-admin-dashboard.widget.recentCustomers.noAccess') }}
    </div>
    {% endblock %}

    {% block frosh_widget_recent_customers_empty_state %}
    <div
        v-else-if="!isLoading && !customers.length"
        class="frosh-widget-recent-customers__empty"
    >
        {{ $tc('frosh-admin-dashboard.widget.recentCustomers.empty') }}
    </div>
    {% endblock %}

    {% block frosh_widget_recent_customers_grid %}
    <sw-data-grid
        v-else
        class="frosh-widget-recent-customers__grid"
        :data-source="customers"
        :columns="columns"
        :is-loading="isLoading"
        :show-selection="false"
        :show-actions="false"
        :plain-appearance="true"
        :allow-inline-edit="false"
        :allow-column-edit="false"
    >
        {% block frosh_widget_recent_customers_column_name %}
        <template #column-firstName="{ item }">
            <router-link :to="{ name: 'sw.customer.detail', params: { id: item.id } }">
                {{ item.lastName }}, {{ item.firstName }}
            </router-link>
        </template>
        {% endblock %}

        {% block frosh_widget_recent_customers_column_saleschannel %}
        <template #column-salesChannel.name="{ item }">
            {{ item.salesChannel ? item.salesChannel.translated.name : '' }}
        </template>
        {% endblock %}

        {% block frosh_widget_recent_customers_column_created %}
        <template #column-createdAt="{ item }">
            <sw-time-ago :date="item.createdAt" />
        </template>
        {% endblock %}
    </sw-data-grid>
    {% endblock %}
</div>
{% endblock %}
