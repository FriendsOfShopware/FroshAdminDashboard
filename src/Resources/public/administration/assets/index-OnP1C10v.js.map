{% block frosh_widget_notes %}
<div class="frosh-widget-notes" :style="{ borderLeftColor: accent }">
    <textarea
        v-model="text"
        class="frosh-widget-notes__textarea"
        :placeholder="$tc('frosh-admin-dashboard.widget.notes.placeholder')"
        rows="6"
        @input="onInput"
    ></textarea>
</div>
{% endblock %}
