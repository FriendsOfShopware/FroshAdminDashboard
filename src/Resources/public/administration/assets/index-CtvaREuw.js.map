{% block frosh_dashboard_settings_modal %}
<sw-modal
    class="frosh-dashboard-settings-modal"
    :title="title"
    @modal-close="$emit('close')"
>
    {% block frosh_dashboard_settings_modal_fields %}
    <div class="frosh-dashboard-settings-modal__fields">
        <template v-for="field in definition.settings" :key="field.name">

            {% block frosh_dashboard_settings_modal_field_text %}
            <mt-text-field
                v-if="field.type === 'text'"
                :model-value="valueOf(field.name)"
                :label="$tc(field.label)"
                :help-text="field.helpText ? $tc(field.helpText) : undefined"
                @update:model-value="updateValue(field.name, $event)"
            />
            {% endblock %}

            {% block frosh_dashboard_settings_modal_field_textarea %}
            <mt-textarea
                v-else-if="field.type === 'textarea'"
                :model-value="valueOf(field.name)"
                :label="$tc(field.label)"
                :help-text="field.helpText ? $tc(field.helpText) : undefined"
                @update:model-value="updateValue(field.name, $event)"
            />
            {% endblock %}

            {% block frosh_dashboard_settings_modal_field_number %}
            <mt-number-field
                v-else-if="field.type === 'number'"
                :model-value="valueOf(field.name)"
                :label="$tc(field.label)"
                :help-text="field.helpText ? $tc(field.helpText) : undefined"
                @update:model-value="updateValue(field.name, $event)"
            />
            {% endblock %}

            {% block frosh_dashboard_settings_modal_field_switch %}
            <mt-switch
                v-else-if="field.type === 'switch'"
                :model-value="!!valueOf(field.name)"
                :label="$tc(field.label)"
                :help-text="field.helpText ? $tc(field.helpText) : undefined"
                @update:model-value="updateValue(field.name, $event)"
            />
            {% endblock %}

            {% block frosh_dashboard_settings_modal_field_select %}
            <mt-select
                v-else-if="field.type === 'select'"
                :model-value="valueOf(field.name)"
                :label="$tc(field.label)"
                :help-text="field.helpText ? $tc(field.helpText) : undefined"
                :options="(field.options || []).map((o) => ({ value: o.value, label: $tc(o.label) }))"
                @update:model-value="updateValue(field.name, $event)"
            />
            {% endblock %}

            {% block frosh_dashboard_settings_modal_field_colorpicker %}
            <mt-colorpicker
                v-else-if="field.type === 'colorpicker'"
                :model-value="valueOf(field.name)"
                :label="$tc(field.label)"
                @update:model-value="updateValue(field.name, $event)"
            />
            {% endblock %}

            {% block frosh_dashboard_settings_modal_field_entity %}
            <sw-entity-single-select
                v-else-if="field.type === 'entity'"
                :value="valueOf(field.name)"
                :entity="field.entity"
                :label="$tc(field.label)"
                :help-text="field.helpText ? $tc(field.helpText) : undefined"
                show-clearable-button
                @update:value="updateValue(field.name, $event)"
            />
            {% endblock %}
        </template>

        {% block frosh_dashboard_settings_modal_empty %}
        <div v-if="!definition.settings || !definition.settings.length" class="frosh-dashboard-settings-modal__empty">
            {{ $tc('frosh-admin-dashboard.settingsModal.empty') }}
        </div>
        {% endblock %}
    </div>
    {% endblock %}

    {% block frosh_dashboard_settings_modal_footer %}
    <template #modal-footer>
        <mt-button variant="secondary" size="small" @click="$emit('close')">
            {{ $tc('global.default.cancel') }}
        </mt-button>
        <mt-button variant="primary" size="small" @click="onSave">
            {{ $tc('global.default.save') }}
        </mt-button>
    </template>
    {% endblock %}
</sw-modal>
{% endblock %}
