{% block frosh_widget_tasks %}
<div class="frosh-widget-tasks">

    {% block frosh_widget_tasks_input %}
    <form class="frosh-widget-tasks__add" @submit.prevent="onAddTask">
        <mt-text-field
            v-model="newTask"
            class="frosh-widget-tasks__add-field"
            :placeholder="$tc('frosh-admin-dashboard.widget.tasks.placeholder')"
            size="small"
        />
        <mt-button
            variant="primary"
            size="small"
            type="submit"
            :aria-label="$tc('frosh-admin-dashboard.widget.tasks.add')"
            :disabled="!newTask.trim()"
        >
            <mt-icon name="regular-plus" size="14px" aria-hidden="true" />
        </mt-button>
    </form>
    {% endblock %}

    {% block frosh_widget_tasks_list %}
    <ul v-if="visibleTasks.length" class="frosh-widget-tasks__list">
        <li
            v-for="task in visibleTasks"
            :key="task.id"
            class="frosh-widget-tasks__item"
            :class="{ 'is--done': task.done }"
        >
            <mt-checkbox
                v-model:checked="task.done"
                class="frosh-widget-tasks__check"
                :aria-label="$tc('frosh-admin-dashboard.widget.tasks.toggle', { task: task.text })"
                @update:checked="persist"
            />
            <template v-if="editingId === task.id">
                <mt-text-field
                    v-model="editText"
                    class="frosh-widget-tasks__edit-input"
                    size="small"
                    :aria-label="$tc('frosh-admin-dashboard.widget.tasks.edit')"
                    @keyup.enter="onSaveEdit(task)"
                    @keyup.escape="onCancelEdit"
                    @blur="onSaveEdit(task)"
                />
            </template>
            <span v-else class="frosh-widget-tasks__text">{{ task.text }}</span>
            <button
                v-if="editingId !== task.id"
                class="frosh-widget-tasks__edit"
                type="button"
                :aria-label="$tc('frosh-admin-dashboard.widget.tasks.edit')"
                @click="onStartEdit(task)"
            >
                <mt-icon name="regular-pencil-s" size="12px" aria-hidden="true" />
            </button>
            <button
                class="frosh-widget-tasks__remove"
                type="button"
                :aria-label="$tc('frosh-admin-dashboard.widget.tasks.remove')"
                @click="onRemove(task.id)"
            >
                <mt-icon name="regular-trash" size="12px" aria-hidden="true" />
            </button>
        </li>
    </ul>
    {% endblock %}

    {% block frosh_widget_tasks_empty %}
    <div v-else class="frosh-widget-tasks__empty">
        {{ $tc('frosh-admin-dashboard.widget.tasks.empty') }}
    </div>
    {% endblock %}

    {% block frosh_widget_tasks_footer %}
    <div v-if="tasks.length" class="frosh-widget-tasks__footer">
        {{ $tc('frosh-admin-dashboard.widget.tasks.openCount', openCount) }}
    </div>
    {% endblock %}
</div>
{% endblock %}
