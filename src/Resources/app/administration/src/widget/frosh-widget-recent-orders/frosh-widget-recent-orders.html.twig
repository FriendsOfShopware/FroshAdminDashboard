{% block frosh_widget_recent_orders %}
<div class="frosh-widget-recent-orders">

    {% block frosh_widget_recent_orders_no_acl %}
    <div v-if="!acl.can('order.viewer')" class="frosh-widget-recent-orders__empty">
        {{ $tc('frosh-admin-dashboard.widget.recentOrders.noAccess') }}
    </div>
    {% endblock %}

    {% block frosh_widget_recent_orders_empty_state %}
    <div
        v-else-if="!isLoading && !orders.length"
        class="frosh-widget-recent-orders__empty"
    >
        {{ $tc('frosh-admin-dashboard.widget.recentOrders.empty') }}
    </div>
    {% endblock %}

    {% block frosh_widget_recent_orders_grid %}
    <sw-data-grid
        v-else
        class="frosh-widget-recent-orders__grid"
        :data-source="orders"
        :columns="columns"
        :is-loading="isLoading"
        :show-selection="false"
        :show-actions="false"
        :plain-appearance="true"
        :allow-inline-edit="false"
        :allow-column-edit="false"
    >
        {% block frosh_widget_recent_orders_column_number %}
        <template #column-orderNumber="{ item }">
            <router-link :to="{ name: 'sw.order.detail', params: { id: item.id } }">
                {{ item.orderNumber }}
            </router-link>
        </template>
        {% endblock %}

        {% block frosh_widget_recent_orders_column_customer %}
        <template #column-orderCustomer.firstName="{ item }">
            <template v-if="item.orderCustomer">
                {{ item.orderCustomer.lastName }}, {{ item.orderCustomer.firstName }}
            </template>
        </template>
        {% endblock %}

        {% block frosh_widget_recent_orders_column_amount %}
        <template #column-amountTotal="{ item }">
            {{ currencyFilter(item.amountTotal, item.currency.isoCode) }}
        </template>
        {% endblock %}

        {% block frosh_widget_recent_orders_column_state %}
        <template #column-stateMachineState.name="{ item }">
            <div class="frosh-widget-recent-orders__state">
                <sw-color-badge
                    :color="getVariantFromOrderState(item)"
                    rounded
                />
                {{ item.stateMachineState.translated.name }}
            </div>
        </template>
        {% endblock %}

        {% block frosh_widget_recent_orders_column_date %}
        <template #column-orderDateTime="{ item }">
            <sw-time-ago :date="item.orderDateTime" />
        </template>
        {% endblock %}
    </sw-data-grid>
    {% endblock %}
</div>
{% endblock %}
