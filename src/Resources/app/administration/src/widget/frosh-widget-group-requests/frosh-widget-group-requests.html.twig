{% block frosh_widget_group_requests %}
<div class="frosh-widget-group-requests">

    {% block frosh_widget_group_requests_no_acl %}
    <div v-if="!acl.can('customer.viewer')" class="frosh-widget-group-requests__empty">
        {{ $tc('frosh-admin-dashboard.widget.groupRequests.noAccess') }}
    </div>
    {% endblock %}

    {% block frosh_widget_group_requests_empty_state %}
    <div
        v-else-if="!isLoading && !customers.length"
        class="frosh-widget-group-requests__empty"
    >
        {{ $tc('frosh-admin-dashboard.widget.groupRequests.empty') }}
    </div>
    {% endblock %}

    {% block frosh_widget_group_requests_grid %}
    <sw-data-grid
        v-else
        class="frosh-widget-group-requests__grid"
        :data-source="customers"
        :columns="columns"
        :is-loading="isLoading"
        :show-selection="false"
        :show-actions="false"
        :plain-appearance="true"
        :allow-inline-edit="false"
        :allow-column-edit="false"
    >
        {% block frosh_widget_group_requests_column_name %}
        <template #column-firstName="{ item }">
            <router-link :to="{ name: 'sw.customer.detail', params: { id: item.id } }">
                {{ item.lastName }}, {{ item.firstName }}
            </router-link>
        </template>
        {% endblock %}

        {% block frosh_widget_group_requests_column_current_group %}
        <template #column-group.name="{ item }">
            {{ item.group ? item.group.translated.name : '' }}
        </template>
        {% endblock %}

        {% block frosh_widget_group_requests_column_requested_group %}
        <template #column-requestedGroup.name="{ item }">
            <sw-label
                v-if="item.requestedGroup"
                appearance="pill"
                size="small"
            >
                {{ item.requestedGroup.translated.name }}
            </sw-label>
        </template>
        {% endblock %}

        {% block frosh_widget_group_requests_column_actions %}
        <template #column-actions="{ item }">
            <div class="frosh-widget-group-requests__actions">
                <mt-button
                    variant="primary"
                    size="x-small"
                    :is-loading="isProcessing(item.id)"
                    :disabled="!acl.can('customer.editor') || isProcessing(item.id)"
                    @click="onAccept(item.id)"
                >
                    {{ $tc('frosh-admin-dashboard.widget.groupRequests.accept') }}
                </mt-button>
                <mt-button
                    variant="critical"
                    size="x-small"
                    :disabled="!acl.can('customer.editor') || isProcessing(item.id)"
                    @click="onDecline(item.id)"
                >
                    {{ $tc('frosh-admin-dashboard.widget.groupRequests.decline') }}
                </mt-button>
            </div>
        </template>
        {% endblock %}
    </sw-data-grid>
    {% endblock %}
</div>
{% endblock %}
